#!/usr/bin/env bash

set -uo pipefail

declare -a PREREQS=("grep" "basename" "less")
declare -F requires &>/dev/null && requires || exit 1

if [ "$#" -ne 1 ]; then
	echo "[!] missing search term" >&2
	exit 2
fi

if [ $(basename $(pwd)) = "kernel" ]; then
	grep --color=always -F -C 3 -r -n --include \*.c --include \*.h --include Makefile --include Kconfig "$1" . | less -F -R
else
	grep --color=always -F -C 3 -r -n "$1" . | less -F -R
fi

