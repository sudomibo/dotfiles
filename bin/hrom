#!/usr/bin/env bash

set -uo pipefail

declare -a PREREQS=("bwrap" "chromium")
declare -F requires &>/dev/null && requires || exit 1

if [ -z "$DBUS_SESSION_BUS_ADDRESS" ]; then
	echo "[!] no D-Bus?" >&2
	exit 2
fi
if [[ ! "$DBUS_SESSION_BUS_ADDRESS" =~ ^unix:path=/tmp/dbus-[a-zA-Z0-9]{1,}, ]]; then
	echo "[!] D-Bus socket location?" >&2
	exit 3
fi

dbus_socket="${DBUS_SESSION_BUS_ADDRESS#unix:path=}"
dbus_socket="${dbus_socket%%,*}"

bwrap --symlink usr/lib /lib \
	--symlink usr/bin /bin \
	--symlink usr/bin /sbin \
	--symlink usr/lib64 /lib64 \
	--ro-bind /usr/lib /usr/lib \
	--ro-bind /usr/lib64 /usr/lib64 \
	--ro-bind /usr/bin /usr/bin \
	--ro-bind /usr/share /usr/share \
	--ro-bind /usr/libexec/chromium /usr/libexec/chromium \
	--ro-bind /etc /etc \
	--dev /dev \
	--dev-bind /dev/dri /dev/dri \
	--proc /proc \
	--ro-bind /sys/dev/char /sys/dev/char \
	--ro-bind /sys/devices /sys/devices \
	--ro-bind /run/dbus /run/dbus \
	--dir "$XDG_RUNTIME_DIR" \
	--ro-bind "$XDG_RUNTIME_DIR/pipewire-0" "$XDG_RUNTIME_DIR/pipewire-0" \
	--ro-bind "$XDG_RUNTIME_DIR/pulse" "$XDG_RUNTIME_DIR/pulse" \
	--ro-bind "$HOME/.Xauthority" "$HOME/.Xauthority" \
	--tmpfs /tmp \
	--ro-bind "$dbus_socket" "$dbus_socket" \
	--bind "$HOME/.config/chromium" "$HOME/.config/chromium" \
	--bind "$HOME/.cache" "$HOME/.cache" \
	--bind "$HOME/Downloads" "$HOME/Downloads" \
	-- chromium

