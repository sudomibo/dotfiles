#!/usr/bin/env bash

set -euo pipefail

declare -a PREREQS=("git" "wget" "tar")
for prereq in "${PREREQS[@]}"; do
	if ! hash "$prereq" 2>/dev/null; then
		echo "[!] $prereq is required but missing" >&2
		exit 1
	fi
done

cd ~
git clone https://github.com/sudomibo/dotfiles.git

ln -s ~/dotfiles/.bash_aliases
ln -s ~/dotfiles/.bash_profile
ln -s ~/dotfiles/.bashrc
ln -s ~/dotfiles/.gitconfig
ln -s ~/dotfiles/.profile
ln -s ~/dotfiles/.tmux.conf
ln -s ~/dotfiles/.vimrc
ln -s ~/dotfiles/.netrc

# vim
git clone https://github.com/vim/vim.git
cd vim/src
make
cd -

# curl
wget https://curl.se/download/curl-8.18.0.tar.gz
tar xvf curl-8.18.0.tar.gz
mv curl-8.18.0 curl
cd curl
./configure --with-openssl --prefix=$HOME/fresh
make
make install
cd -

# gef
git clone https://github.com/sudomibo/gef.git

# binutils
mkdir -p ~/tmp
cd ~/tmp
V=2.46.0
ARCH=x86_64 # target architecture (aarch64, mips64, etc.)
wget -nc https://ftp.gnu.org/gnu/binutils/binutils-$V.tar.gz
wget -nc https://ftp.gnu.org/gnu/binutils/binutils-$V.tar.gz.sig
gpg --keyserver keys.gnupg.net --recv-keys 3A24BC1E8FB409FA9F14371813FCEF89DD9E3C4F
gpg --verify binutils-$V.tar.gz.sig
tar xvf binutils-$V.tar.gz
mkdir binutils-build
cd binutils-build
export AR=ar
export AS=as
../binutils-$V/configure \
  --prefix=${PREFIX:-$HOME/fresh} \
  --target=$ARCH-unknown-linux-gnu \
  --disable-static \
  --disable-multilib \
  --disable-werror \
  --disable-nls
MAKE=gmake
hash gmake || MAKE=make
$MAKE -j clean all
$MAKE install

# pwntools
git clone https://github.com/sudomibo/pwntools.git
cd pwntools
git checkout stable
python3 -m venv ~/pwn
~/pwn/bin/pip install --upgrade pip
~/pwn/bin/pip install --upgrade ~/pwntools

mkdir -p ~/bin
ln -s ~/dotfiles/bin/install_dotfiles ~/bin/install_dotfiles
ln -s ~/dotfiles/bin/di ~/bin/di
ln -s ~/dotfiles/bin/gitbr ~/bin/gitbr
ln -s ~/dotfiles/bin/kb2proj ~/bin/kb2proj
ln -s ~/dotfiles/bin/v ~/bin/v
ln -s ~/dotfiles/bin/s ~/bin/s
ln -s ~/dotfiles/bin/si ~/bin/si
ln -s ~/dotfiles/bin/dcp ~/bin/dcp
ln -s ~/dotfiles/bin/sign_key ~/bin/sign_key
ln -s ~/dotfiles/bin/ikconfigs ~/bin/ikconfigs
ln -s ~/dotfiles/bin/bin2hex ~/bin/bin2hex
ln -s ~/dotfiles/bin/text2bin ~/bin/text2bin
ln -s ~/dotfiles/bin/um ~/bin/um
ln -s ~/dotfiles/bin/severity ~/bin/severity
ln -s ~/dotfiles/bin/gitcop ~/bin/gitcop
ln -s ~/dotfiles/bin/sysinfo ~/bin/sysinfo
ln -s ~/dotfiles/bin/tmux_sysinfo ~/bin/tmux_sysinfo
ln -s ~/dotfiles/bin/git-obs ~/bin/git-obs
ln -s ~/dotfiles/bin/n2hr ~/bin/n2hr
ln -s ~/dotfiles/bin/n2html ~/bin/n2html
ln -s ~/dotfiles/bin/uncpio ~/bin/uncpio
ln -s ~/dotfiles/bin/backup ~/bin/backup
ln -s ~/dotfiles/bin/sink ~/bin/sink
ln -s ~/dotfiles/bin/icd ~/bin/icd
ln -s ~/vim/src/vim ~/bin/vim
ln -s ~/fresh/bin/curl ~/bin/curl
ln -s ~/pwn/bin/pwn ~/bin/pwn

mkdir -p ~/.config
ln -s ~/dotfiles/.config/mtk.ini ~/.config/mtk.ini

mkdir -p ~/.config/osc
ln -s ~/dotfiles/.config/osc/oscrc ~/.config/osc/oscrc

mkdir -p ~/.config/python-bugzilla
ln -s ~/dotfiles/.config/python-bugzilla/bugzillarc ~/.config/python-bugzilla/bugzillarc

mkdir -p ~/.config/gdb
ln -s ~/dotfiles/.config/gdb/gdbinit ~/.config/gdb/gdbinit

